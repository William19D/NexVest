# --- Secrets (NEVER commit) ---
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
env/
build/
dist/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Node ---
node_modules/
**/node_modules/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# --- Build artifacts ---
**/dist/
**/dist-ssr/
*.local

# --- ETL outputs (regenerated by the ETL script) ---
Nexvest-Back-FASTAPI/etl/historicos/*.json
Nexvest-Back-FASTAPI/etl/resultados_analisis/

# --- IDE / OS ---
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# --- Docker / Caddy runtime ---
caddy_data/
caddy_config/
caddy_logs/

# --- Misc ---
*.pdf
