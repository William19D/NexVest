# NexVest - variables del stack de docker-compose
# ------------------------------------------------
# Copiar a .env y completar antes de levantar el stack:
#   cp .env.example .env

# Dominio que sirve la SPA y proxea /api al backend.
# Acepta valores como:
#   - nexvest.tudominio.com
#   - 5.75.123.45.nip.io        (sin registrar DNS propio)
#   - :80                       (HTTP plano para pruebas, sin HTTPS)
DOMAIN=nexvest.tudominio.com
